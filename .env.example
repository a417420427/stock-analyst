# 应用配置
APP_NAME=StockAnalyst
DEBUG=true

# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stock_analyst
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/stock_analyst

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 行情数据源 API Keys
TUSHARE_TOKEN=
AKSHARE_ENABLED=true
ALPHA_VANTAGE_KEY=

# 推送
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
DINGTALK_WEBHOOK_URL=

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# JWT
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24h

# 行情配置
MARKET_A_HOURS=9:30-11:30/13:00-15:00
MARKET_HK_HOURS=9:30-12:00/13:00-16:00
MARKET_US_HOURS=9:30-16:00  # ET

# 扫描间隔（秒）
SCAN_INTERVAL_DEFAULT=300
SCAN_INTERVAL_FAST=60
